# ============================================================
# .env.example — Copy this file to .env and fill in your keys
# ============================================================
# None of these are required to run the project with default settings.
# The system works fully out-of-the-box using:
#   - HuggingFace Transformers (local LLM, no API key needed)
#   - DuckDuckGo Search (free, no API key needed)
#   - Model cache stored in: {project_root}/models/

# ── OPTIONAL: Custom model cache directory ────────────────────
# By default, downloaded models (Qwen, BAAI/bge-m3, etc.) are saved
# in the models/ folder inside the project root directory.
# Set this to redirect cache to another drive/location:
# HF_HOME=D:/my_hf_cache

# ── OPTIONAL: Faster cloud LLM via Groq API ──────────────────
# If set, the system auto-routes to Groq instead of local model.
# Get free keys at: https://console.groq.com
# GROQ_API_KEY=gsk_your_key_here
# Multiple keys for automatic rotation on rate-limit:
# GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3

# ── OPTIONAL: Better search results via Tavily ────────────────
# Get a free key at: https://app.tavily.com
# Without this, the system falls back to DuckDuckGo automatically.
# TAVILY_API_KEY=tvly_your_key_here

