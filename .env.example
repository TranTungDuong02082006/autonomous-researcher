# ============================================================
# .env.example — Copy this file to .env and fill in your keys
# ============================================================
# The app runs fully out-of-the-box WITHOUT any .env file:
#   - Qwen2.5-14B runs locally via HuggingFace Transformers
#   - Search uses DuckDuckGo (free, no key needed)
#   - Model cache goes to {project_root}/models/
#
# Fine-tuned models (reviewer LoRA + reranker) are auto-downloaded
# from Kaggle when KAGGLE credentials are present.

# REQUIRED for fine-tuned model auto-download
# Get your credentials: https://www.kaggle.com/settings > API > "Create New Token"
# KAGGLE_USERNAME=your_kaggle_username
# KAGGLE_KEY=your_kaggle_api_key

# OPTIONAL: Custom model cache directory
# By default Qwen and embedding models go to {project_root}/models/
# HF_HOME=D:/my_hf_cache

# OPTIONAL: Faster cloud LLM via Groq API
# Auto-detected: if key starts with "gsk_", routes to Groq instead of local model.
# Get free keys at: https://console.groq.com
# GROQ_API_KEY=gsk_your_key_here
# Multiple keys for auto key-rotation on rate-limit:
# GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3

# OPTIONAL: Better search via Tavily
# Without this, falls back to DuckDuckGo automatically.
# TAVILY_API_KEY=tvly_your_key_here


